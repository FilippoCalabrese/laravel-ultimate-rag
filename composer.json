{
    "name": "sellinnate/rag-engine",
    "description": "Enterprise Retrieval-Augmented Generation engine for Laravel: ingestion, parsing, chunking, embedding, vector store, retrieval, reranking, BYOK security and multi-tenancy.",
    "keywords": [
        "sellinnate",
        "laravel",
        "rag",
        "retrieval-augmented-generation",
        "embeddings",
        "vector-search",
        "qdrant",
        "pgvector"
    ],
    "homepage": "https://github.com/Sellinnate/laravel-ultimate-rag",
    "license": "MIT",
    "authors": [
        {
            "name": "Filippo Calabrese",
            "email": "filippo@selli.io",
            "role": "Developer"
        }
    ],
    "support": {
        "docs": "https://laravel-rag-engine.selli.io",
        "issues": "https://github.com/Sellinnate/laravel-ultimate-rag/issues",
        "source": "https://github.com/Sellinnate/laravel-ultimate-rag"
    },
    "require": {
        "php": "^8.2",
        "spatie/laravel-package-tools": "^1.16",
        "illuminate/contracts": "^11.0||^12.0||^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.8",
        "orchestra/testbench": "^11.0.0||^10.0.0||^9.0.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "smalot/pdfparser": "^2.0",
        "aws/aws-sdk-php": "^3.300"
    },
    "suggest": {
        "smalot/pdfparser": "Parse text-based PDF documents",
        "aws/aws-sdk-php": "Use AWS KMS as the BYOK key-management driver (kms.aws)"
    },
    "autoload": {
        "psr-4": {
            "Sellinnate\\RagEngine\\": "src/",
            "Sellinnate\\RagEngine\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sellinnate\\RagEngine\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage --min=90",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Sellinnate\\RagEngine\\RagEngineServiceProvider"
            ],
            "aliases": {
                "Rag": "Sellinnate\\RagEngine\\Facades\\Rag"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
