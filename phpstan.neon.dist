includes:
    - phpstan-baseline.neon

parameters:
    level: 8
    phpVersion: 80200
    paths:
        - src
        - database
    tmpDir: build/phpstan
    ignoreErrors:
        # Consumer-facing traits (used in host apps' models, not within src).
        -
            identifier: trait.unused
            path: src/Concerns/Searchable.php
        -
            identifier: trait.unused
            path: src/Concerns/HasEmbeddings.php
        -
            identifier: trait.unused
            path: src/Concerns/TouchesEmbeddingParents.php
