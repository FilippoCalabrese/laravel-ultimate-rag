# =============================================================================
# sellinnate/rag-engine — environment variables
# -----------------------------------------------------------------------------
# Copy the lines you need into your app's .env. API keys ALWAYS live here, never
# in config/rag-engine.php (that file is committed and config:cache-safe).
# Only set the providers you actually use; everything has a sane default.
# =============================================================================

# --- Defaults: which driver each stage uses -------------------------------
RAG_EMBEDDER=fake          # openai | azure-openai | mistral | jina | voyage | cohere | gemini | huggingface | ollama | fake
RAG_VECTOR_STORE=database  # database | qdrant
RAG_LLM=null               # null | fake | (your generation driver)
RAG_RERANKER=null          # null | fake
RAG_TOKENIZER=approximate

# =============================================================================
# Embedding providers — set the key(s) for the provider(s) you use.
# =============================================================================

# --- OpenAI (global; mandatory baseline) ----------------------------------
RAG_OPENAI_API_KEY=
# RAG_OPENAI_MODEL=text-embedding-3-small
# RAG_OPENAI_DIMENSIONS=1536
# RAG_OPENAI_ORG=                 # optional OpenAI-Organization header
# RAG_OPENAI_BASE_URL=https://api.openai.com/v1
# RAG_OPENAI_COST_PER_1K=0.00002

# --- Azure OpenAI (EU-resident in an EU region) ---------------------------
RAG_AZURE_API_KEY=
RAG_AZURE_ENDPOINT=https://<resource>.openai.azure.com
RAG_AZURE_DEPLOYMENT=<your-embedding-deployment>
RAG_AZURE_API_VERSION=2024-02-01
# RAG_AZURE_MODEL=text-embedding-3-small
# RAG_AZURE_DIMENSIONS=1536

# --- Mistral (EU) ----------------------------------------------------------
RAG_MISTRAL_API_KEY=
# RAG_MISTRAL_MODEL=mistral-embed
# RAG_MISTRAL_BASE_URL=https://api.mistral.ai/v1

# --- Jina AI (EU) ----------------------------------------------------------
RAG_JINA_API_KEY=
# RAG_JINA_MODEL=jina-embeddings-v3
# RAG_JINA_DIMENSIONS=1024
# RAG_JINA_TASK=retrieval.passage   # retrieval.passage | retrieval.query | ...

# --- Voyage AI (global) ----------------------------------------------------
RAG_VOYAGE_API_KEY=
# RAG_VOYAGE_MODEL=voyage-3
# RAG_VOYAGE_DIMENSIONS=1024
# RAG_VOYAGE_INPUT_TYPE=document    # document | query

# --- Cohere (global) -------------------------------------------------------
RAG_COHERE_API_KEY=
# RAG_COHERE_MODEL=embed-multilingual-v3.0
# RAG_COHERE_DIMENSIONS=1024
# RAG_COHERE_INPUT_TYPE=search_document   # search_document | search_query

# --- Google Gemini (global) ------------------------------------------------
RAG_GEMINI_API_KEY=
# RAG_GEMINI_MODEL=text-embedding-004
# RAG_GEMINI_DIMENSIONS=768

# --- Hugging Face (global API, or self-hosted TEI) -------------------------
RAG_HF_API_KEY=
# RAG_HF_MODEL=BAAI/bge-small-en-v1.5
# RAG_HF_DIMENSIONS=384
# RAG_HF_BASE_URL=https://api-inference.huggingface.co

# --- Ollama (self-hosted; no API key) -------------------------------------
RAG_OLLAMA_BASE_URL=http://localhost:11434
# RAG_OLLAMA_MODEL=nomic-embed-text
# RAG_OLLAMA_DIMENSIONS=768

# =============================================================================
# Vector store
# =============================================================================
# RAG_PGVECTOR_CONNECTION=pgsql
RAG_QDRANT_HOST=http://localhost:6333
RAG_QDRANT_API_KEY=
# RAG_QDRANT_QUANTIZATION=

# =============================================================================
# Security, tenancy & ingestion
# =============================================================================
RAG_ENCRYPTION_ENABLED=true
RAG_KMS=local
# RAG_KMS_STORE=array               # array | file
# RAG_KMS_MASTER_KEY=               # base64 32-byte key when store=file
# RAG_KMS_KEYSTORE=

RAG_PII_REDACTION=true
RAG_PII_STRATEGY=mask               # mask | tokenize

RAG_TENANCY_ISOLATION=namespace
RAG_TENANCY_STRICT=false
RAG_DEFAULT_TENANT=default

RAG_INGESTION_SYNC=false
# RAG_MAX_UPLOAD_BYTES=26214400
